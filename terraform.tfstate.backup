            "checksum_sha256": "",
            "content": "\u003c!DOCTYPE html\u003e\r\n\u003chtml lang=\"ja\"\u003e\r\n\u003chead\u003e\r\n  \u003cmeta charset=\"UTF-8\"\u003e\r\n  \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\r\n  \u003ctitle\u003eお問い合わせ\u003c/title\u003e\r\n  \u003cstyle\u003e\r\n    * { box-sizing: border-box; margin: 0; padding: 0; }\r\n    body {\r\n      font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;\r\n      background: #f5f5f5;\r\n      min-height: 100vh;\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      padding: 2rem 1rem;\r\n    }\r\n    .card {\r\n      background: #fff;\r\n      border: 1px solid #e5e5e5;\r\n      border-radius: 12px;\r\n      padding: 2rem;\r\n      width: 100%;\r\n      max-width: 560px;\r\n    }\r\n    h2 {\r\n      font-size: 18px;\r\n      font-weight: 500;\r\n      color: #111;\r\n      margin-bottom: 0.25rem;\r\n    }\r\n    .subtitle {\r\n      font-size: 14px;\r\n      color: #666;\r\n      margin-bottom: 1.5rem;\r\n    }\r\n    label {\r\n      display: block;\r\n      font-size: 13px;\r\n      color: #555;\r\n      margin-bottom: 6px;\r\n    }\r\n    .required { color: #e53e3e; }\r\n    .field { margin-bottom: 1rem; }\r\n    input[type=\"text\"],\r\n    input[type=\"email\"],\r\n    textarea {\r\n      width: 100%;\r\n      padding: 8px 12px;\r\n      font-size: 14px;\r\n      border: 1px solid #ddd;\r\n      border-radius: 8px;\r\n      outline: none;\r\n      transition: border-color 0.15s;\r\n      font-family: inherit;\r\n    }\r\n    input:focus, textarea:focus { border-color: #888; }\r\n    textarea { resize: vertical; }\r\n    .char-count {\r\n      font-size: 12px;\r\n      color: #999;\r\n      text-align: right;\r\n      margin-top: 4px;\r\n    }\r\n    .char-count.over { color: #e53e3e; }\r\n    .error-msg {\r\n      display: none;\r\n      background: #fff5f5;\r\n      border: 1px solid #feb2b2;\r\n      border-radius: 8px;\r\n      padding: 10px 14px;\r\n      font-size: 13px;\r\n      color: #c53030;\r\n      margin-bottom: 1rem;\r\n    }\r\n    .btn-submit {\r\n      width: 100%;\r\n      padding: 10px;\r\n      font-size: 15px;\r\n      cursor: pointer;\r\n      background: #fff;\r\n      border: 1px solid #ccc;\r\n      border-radius: 8px;\r\n      transition: background 0.15s;\r\n      font-family: inherit;\r\n    }\r\n    .btn-submit:hover { background: #f5f5f5; }\r\n    .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }\r\n    .success-wrap {\r\n      display: none;\r\n      text-align: center;\r\n      padding: 2rem 0;\r\n    }\r\n    .success-icon {\r\n      width: 48px; height: 48px;\r\n      border-radius: 50%;\r\n      background: #f0fff4;\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      margin: 0 auto 1rem;\r\n    }\r\n    .success-title {\r\n      font-size: 16px;\r\n      font-weight: 500;\r\n      color: #111;\r\n      margin-bottom: 0.5rem;\r\n    }\r\n    .success-body {\r\n      font-size: 14px;\r\n      color: #666;\r\n      margin-bottom: 1.5rem;\r\n      line-height: 1.6;\r\n    }\r\n    .btn-reset {\r\n      font-size: 13px;\r\n      cursor: pointer;\r\n      padding: 8px 20px;\r\n      background: #fff;\r\n      border: 1px solid #ccc;\r\n      border-radius: 8px;\r\n      font-family: inherit;\r\n    }\r\n    .btn-reset:hover { background: #f5f5f5; }\r\n  \u003c/style\u003e\r\n\u003c/head\u003e\r\n\u003cbody\u003e\r\n\u003cdiv class=\"card\"\u003e\r\n  \u003ch2\u003eお問い合わせ\u003c/h2\u003e\r\n  \u003cp class=\"subtitle\"\u003eご質問・ご意見はこちらからお送りください。\u003c/p\u003e\r\n\r\n  \u003cdiv id=\"form-body\"\u003e\r\n    \u003cdiv class=\"field\"\u003e\r\n      \u003clabel\u003eお名前 \u003cspan class=\"required\"\u003e*\u003c/span\u003e\u003c/label\u003e\r\n      \u003cinput type=\"text\" id=\"name\" placeholder=\"山田 太郎\"\u003e\r\n    \u003c/div\u003e\r\n    \u003cdiv class=\"field\"\u003e\r\n      \u003clabel\u003eメールアドレス \u003cspan class=\"required\"\u003e*\u003c/span\u003e\u003c/label\u003e\r\n      \u003cinput type=\"email\" id=\"email\" placeholder=\"taro@example.com\"\u003e\r\n    \u003c/div\u003e\r\n    \u003cdiv class=\"field\"\u003e\r\n      \u003clabel\u003e件名\u003c/label\u003e\r\n      \u003cinput type=\"text\" id=\"subject\" placeholder=\"お問い合わせの件名\"\u003e\r\n    \u003c/div\u003e\r\n    \u003cdiv class=\"field\" style=\"margin-bottom:1.5rem;\"\u003e\r\n      \u003clabel\u003eお問い合わせ内容 \u003cspan class=\"required\"\u003e*\u003c/span\u003e\u003c/label\u003e\r\n      \u003ctextarea id=\"message\" rows=\"5\" placeholder=\"ご質問・ご意見をご記入ください\"\u003e\u003c/textarea\u003e\r\n      \u003cdiv id=\"char-count\" class=\"char-count\"\u003e0 / 500文字\u003c/div\u003e\r\n    \u003c/div\u003e\r\n\r\n    \u003cdiv id=\"error-msg\" class=\"error-msg\"\u003e\u003c/div\u003e\r\n\r\n    \u003cbutton id=\"submit-btn\" class=\"btn-submit\" onclick=\"handleSubmit()\"\u003e送信する\u003c/button\u003e\r\n  \u003c/div\u003e\r\n\r\n  \u003cdiv id=\"success-msg\" class=\"success-wrap\"\u003e\r\n    \u003cdiv class=\"success-icon\"\u003e\r\n      \u003csvg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\"\u003e\r\n        \u003cpath d=\"M5 11l4.5 4.5L17 7\" stroke=\"#38a169\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/\u003e\r\n      \u003c/svg\u003e\r\n    \u003c/div\u003e\r\n    \u003cp class=\"success-title\"\u003e送信が完了しました\u003c/p\u003e\r\n    \u003cp class=\"success-body\"\u003eお問い合わせありがとうございます。\u003cbr\u003e内容を確認次第、ご連絡いたします。\u003c/p\u003e\r\n    \u003cbutton onclick=\"resetForm()\" class=\"btn-reset\"\u003e新しいお問い合わせ\u003c/button\u003e\r\n  \u003c/div\u003e\r\n\u003c/div\u003e\r\n\r\n\u003cscript\u003e\r\n  const API_ENDPOINT = \"https://9tv2kbxpih.execute-api.us-east-1.amazonaws.com/prod/contact\";\r\n  const MAX = 500;\r\n  const msgEl = document.getElementById('message');\r\n  const countEl = document.getElementById('char-count');\r\n\r\n  msgEl.addEventListener('input', () =\u003e {\r\n    const len = msgEl.value.length;\r\n    countEl.textContent = len + ' / ' + MAX + '文字';\r\n    countEl.className = 'char-count' + (len \u003e MAX ? ' over' : '');\r\n  });\r\n\r\n  async function handleSubmit() {\r\n    const name = document.getElementById('name').value.trim();\r\n    const email = document.getElementById('email').value.trim();\r\n    const subject = document.getElementById('subject').value.trim();\r\n    const message = document.getElementById('message').value.trim();\r\n    const errEl = document.getElementById('error-msg');\r\n    const btn = document.getElementById('submit-btn');\r\n\r\n    errEl.style.display = 'none';\r\n\r\n    if (!name || !email || !message) {\r\n      errEl.textContent = '※ お名前・メールアドレス・お問い合わせ内容は必須項目です。';\r\n      errEl.style.display = 'block';\r\n      return;\r\n    }\r\n    if (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email)) {\r\n      errEl.textContent = '※ 正しいメールアドレスを入力してください。';\r\n      errEl.style.display = 'block';\r\n      return;\r\n    }\r\n    if (message.length \u003e MAX) {\r\n      errEl.textContent = '※ お問い合わせ内容は' + MAX + '文字以内で入力してください。';\r\n      errEl.style.display = 'block';\r\n      return;\r\n    }\r\n\r\n    btn.disabled = true;\r\n    btn.textContent = '送信中...';\r\n\r\n    try {\r\n      const res = await fetch(API_ENDPOINT, {\r\n        method: 'POST',\r\n        headers: { 'Content-Type': 'application/json' },\r\n        body: JSON.stringify({ name, email, subject, message })\r\n      });\r\n\r\n      if (!res.ok) throw new Error('API error: ' + res.status);\r\n\r\n      document.getElementById('form-body').style.display = 'none';\r\n      document.getElementById('success-msg').style.display = 'block';\r\n    } catch (e) {\r\n      errEl.textContent = '※ 送信に失敗しました。しばらくしてから再度お試しください。';\r\n      errEl.style.display = 'block';\r\n      btn.disabled = false;\r\n      btn.textContent = '送信する';\r\n    }\r\n  }\r\n\r\n  function resetForm() {\r\n    ['name', 'email', 'subject', 'message'].forEach(id =\u003e {\r\n      document.getElementById(id).value = '';\r\n    });\r\n    countEl.textContent = '0 / ' + MAX + '文字';\r\n    countEl.className = 'char-count';\r\n    document.getElementById('error-msg').style.display = 'none';\r\n    document.getElementById('form-body').style.display = 'block';\r\n    document.getElementById('success-msg').style.display = 'none';\r\n    document.getElementById('submit-btn').disabled = false;\r\n    document.getElementById('submit-btn').textContent = '送信する';\r\n  }\r\n\u003c/script\u003e\r\n\u003c/body\u003e\r\n\u003c/html\u003e\r\n",
            "content_base64": null,
