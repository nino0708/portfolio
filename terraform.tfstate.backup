      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "acl": null,
            "arn": "arn:aws:s3:::20260412-aws-s3-test1/contact_form.html",
            "bucket": "20260412-aws-s3-test1",
            "bucket_key_enabled": false,
            "cache_control": "",
            "checksum_algorithm": null,
