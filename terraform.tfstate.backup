    {
      "mode": "managed",
      "type": "aws_s3_object",
      "name": "admin_html",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "acl": null,
            "arn": "arn:aws:s3:::20260412-aws-s3-test1/admin.html",
            "bucket": "20260412-aws-s3-test1",
            "bucket_key_enabled": false,
            "cache_control": "",
            "checksum_algorithm": null,
            "checksum_crc32": "",
            "checksum_crc32c": "",
            "checksum_crc64nvme": "",
            "checksum_sha1": "",
            "checksum_sha256": "",
            "content": "\u003c!DOCTYPE html\u003e\r\n\u003chtml lang=\"ja\"\u003e\r\n\u003chead\u003e\r\n  \u003cmeta charset=\"UTF-8\"\u003e\r\n  \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\r\n  \u003ctitle\u003e管理画面 - お問い合わせ一覧\u003c/title\u003e\r\n  \u003clink href=\"https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500\u0026family=Noto+Sans+JP:wght@400;500\u0026display=swap\" rel=\"stylesheet\"\u003e\r\n  \u003cstyle\u003e\r\n    :root {\r\n      --bg: #0f0f0f;\r\n      --surface: #181818;\r\n      --border: #2a2a2a;\r\n      --border-light: #333;\r\n      --text: #e8e8e8;\r\n      --text-muted: #666;\r\n      --text-dim: #444;\r\n      --accent: #c8f55a;\r\n      --accent-dim: rgba(200, 245, 90, 0.12);\r\n      --danger: #ff5f5f;\r\n      --mono: 'IBM Plex Mono', monospace;\r\n      --sans: 'Noto Sans JP', sans-serif;\r\n    }\r\n    * { box-sizing: border-box; margin: 0; padding: 0; }\r\n    body {\r\n      background: var(--bg);\r\n      color: var(--text);\r\n      font-family: var(--sans);\r\n      min-height: 100vh;\r\n    }\r\n\r\n    /* Header */\r\n    header {\r\n      border-bottom: 1px solid var(--border);\r\n      padding: 0 2rem;\r\n      height: 56px;\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: space-between;\r\n      position: sticky;\r\n      top: 0;\r\n      background: var(--bg);\r\n      z-index: 100;\r\n    }\r\n    .logo {\r\n      font-family: var(--mono);\r\n      font-size: 13px;\r\n      color: var(--accent);\r\n      letter-spacing: 0.05em;\r\n    }\r\n    .header-right {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: 1rem;\r\n    }\r\n    .status-dot {\r\n      width: 6px; height: 6px;\r\n      border-radius: 50%;\r\n      background: var(--accent);\r\n      animation: pulse 2s infinite;\r\n    }\r\n    @keyframes pulse {\r\n      0%, 100% { opacity: 1; }\r\n      50% { opacity: 0.3; }\r\n    }\r\n    .status-text {\r\n      font-family: var(--mono);\r\n      font-size: 11px;\r\n      color: var(--text-muted);\r\n    }\r\n\r\n    /* Login */\r\n    #login-screen {\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      min-height: calc(100vh - 56px);\r\n      padding: 2rem;\r\n    }\r\n    .login-card {\r\n      background: var(--surface);\r\n      border: 1px solid var(--border);\r\n      border-radius: 4px;\r\n      padding: 2.5rem;\r\n      width: 100%;\r\n      max-width: 360px;\r\n    }\r\n    .login-card h2 {\r\n      font-family: var(--mono);\r\n      font-size: 14px;\r\n      font-weight: 500;\r\n      color: var(--accent);\r\n      margin-bottom: 0.5rem;\r\n      letter-spacing: 0.05em;\r\n    }\r\n    .login-card p {\r\n      font-size: 13px;\r\n      color: var(--text-muted);\r\n      margin-bottom: 2rem;\r\n    }\r\n    .field { margin-bottom: 1rem; }\r\n    .field label {\r\n      display: block;\r\n      font-family: var(--mono);\r\n      font-size: 11px;\r\n      color: var(--text-muted);\r\n      margin-bottom: 6px;\r\n      letter-spacing: 0.08em;\r\n      text-transform: uppercase;\r\n    }\r\n    .field input {\r\n      width: 100%;\r\n      background: var(--bg);\r\n      border: 1px solid var(--border-light);\r\n      border-radius: 2px;\r\n      padding: 9px 12px;\r\n      font-size: 13px;\r\n      color: var(--text);\r\n      font-family: var(--mono);\r\n      outline: none;\r\n      transition: border-color 0.15s;\r\n    }\r\n    .field input:focus { border-color: var(--accent); }\r\n    .btn-login {\r\n      width: 100%;\r\n      padding: 10px;\r\n      background: var(--accent);\r\n      border: none;\r\n      border-radius: 2px;\r\n      font-family: var(--mono);\r\n      font-size: 13px;\r\n      font-weight: 500;\r\n      color: #0f0f0f;\r\n      cursor: pointer;\r\n      margin-top: 0.5rem;\r\n      transition: opacity 0.15s;\r\n      letter-spacing: 0.05em;\r\n    }\r\n    .btn-login:hover { opacity: 0.85; }\r\n    .login-error {\r\n      display: none;\r\n      font-size: 12px;\r\n      color: var(--danger);\r\n      margin-top: 0.75rem;\r\n      font-family: var(--mono);\r\n    }\r\n\r\n    /* Dashboard */\r\n    #dashboard { display: none; }\r\n    .container { padding: 2rem; max-width: 1200px; margin: 0 auto; }\r\n\r\n    /* Stats */\r\n    .stats {\r\n      display: grid;\r\n      grid-template-columns: repeat(3, 1fr);\r\n      gap: 1px;\r\n      background: var(--border);\r\n      border: 1px solid var(--border);\r\n      border-radius: 4px;\r\n      overflow: hidden;\r\n      margin-bottom: 2rem;\r\n    }\r\n    .stat {\r\n      background: var(--surface);\r\n      padding: 1.25rem 1.5rem;\r\n    }\r\n    .stat-label {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      color: var(--text-muted);\r\n      letter-spacing: 0.1em;\r\n      text-transform: uppercase;\r\n      margin-bottom: 0.5rem;\r\n    }\r\n    .stat-value {\r\n      font-family: var(--mono);\r\n      font-size: 28px;\r\n      font-weight: 500;\r\n      color: var(--accent);\r\n    }\r\n\r\n    /* Toolbar */\r\n    .toolbar {\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: space-between;\r\n      margin-bottom: 1rem;\r\n      gap: 1rem;\r\n    }\r\n    .toolbar-left {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: 0.75rem;\r\n    }\r\n    .section-title {\r\n      font-family: var(--mono);\r\n      font-size: 12px;\r\n      color: var(--text-muted);\r\n      letter-spacing: 0.08em;\r\n      text-transform: uppercase;\r\n    }\r\n    .search-input {\r\n      background: var(--surface);\r\n      border: 1px solid var(--border-light);\r\n      border-radius: 2px;\r\n      padding: 7px 12px;\r\n      font-size: 13px;\r\n      color: var(--text);\r\n      font-family: var(--mono);\r\n      outline: none;\r\n      width: 220px;\r\n      transition: border-color 0.15s;\r\n    }\r\n    .search-input:focus { border-color: var(--accent); }\r\n    .search-input::placeholder { color: var(--text-dim); }\r\n    .btn-refresh {\r\n      background: transparent;\r\n      border: 1px solid var(--border-light);\r\n      border-radius: 2px;\r\n      padding: 7px 14px;\r\n      font-family: var(--mono);\r\n      font-size: 11px;\r\n      color: var(--text-muted);\r\n      cursor: pointer;\r\n      letter-spacing: 0.05em;\r\n      transition: all 0.15s;\r\n    }\r\n    .btn-refresh:hover {\r\n      border-color: var(--accent);\r\n      color: var(--accent);\r\n    }\r\n\r\n    /* Table */\r\n    .table-wrap {\r\n      border: 1px solid var(--border);\r\n      border-radius: 4px;\r\n      overflow: hidden;\r\n    }\r\n    table {\r\n      width: 100%;\r\n      border-collapse: collapse;\r\n      font-size: 13px;\r\n    }\r\n    thead {\r\n      background: var(--surface);\r\n      border-bottom: 1px solid var(--border);\r\n    }\r\n    th {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      font-weight: 500;\r\n      color: var(--text-muted);\r\n      letter-spacing: 0.1em;\r\n      text-transform: uppercase;\r\n      padding: 12px 16px;\r\n      text-align: left;\r\n      white-space: nowrap;\r\n    }\r\n    tbody tr {\r\n      border-bottom: 1px solid var(--border);\r\n      transition: background 0.1s;\r\n      cursor: pointer;\r\n    }\r\n    tbody tr:last-child { border-bottom: none; }\r\n    tbody tr:hover { background: var(--surface); }\r\n    td {\r\n      padding: 14px 16px;\r\n      color: var(--text);\r\n      vertical-align: top;\r\n    }\r\n    .td-id {\r\n      font-family: var(--mono);\r\n      font-size: 11px;\r\n      color: var(--text-dim);\r\n      max-width: 80px;\r\n      overflow: hidden;\r\n      text-overflow: ellipsis;\r\n      white-space: nowrap;\r\n    }\r\n    .td-name { font-weight: 500; white-space: nowrap; }\r\n    .td-email {\r\n      font-family: var(--mono);\r\n      font-size: 12px;\r\n      color: var(--accent);\r\n    }\r\n    .td-subject {\r\n      max-width: 180px;\r\n      overflow: hidden;\r\n      text-overflow: ellipsis;\r\n      white-space: nowrap;\r\n      color: var(--text-muted);\r\n    }\r\n    .td-message {\r\n      max-width: 240px;\r\n      overflow: hidden;\r\n      text-overflow: ellipsis;\r\n      white-space: nowrap;\r\n      color: var(--text-muted);\r\n      font-size: 12px;\r\n    }\r\n    .td-time {\r\n      font-family: var(--mono);\r\n      font-size: 11px;\r\n      color: var(--text-dim);\r\n      white-space: nowrap;\r\n    }\r\n\r\n    /* Empty / Loading */\r\n    .empty-row td {\r\n      text-align: center;\r\n      padding: 3rem;\r\n      color: var(--text-muted);\r\n      font-family: var(--mono);\r\n      font-size: 12px;\r\n    }\r\n\r\n    /* Modal */\r\n    .modal-overlay {\r\n      display: none;\r\n      position: fixed;\r\n      inset: 0;\r\n      background: rgba(0,0,0,0.75);\r\n      z-index: 200;\r\n      align-items: center;\r\n      justify-content: center;\r\n      padding: 2rem;\r\n    }\r\n    .modal-overlay.open { display: flex; }\r\n    .modal {\r\n      background: var(--surface);\r\n      border: 1px solid var(--border-light);\r\n      border-radius: 4px;\r\n      padding: 2rem;\r\n      width: 100%;\r\n      max-width: 560px;\r\n      position: relative;\r\n    }\r\n    .modal-header {\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: space-between;\r\n      margin-bottom: 1.5rem;\r\n      padding-bottom: 1rem;\r\n      border-bottom: 1px solid var(--border);\r\n    }\r\n    .modal-title {\r\n      font-family: var(--mono);\r\n      font-size: 12px;\r\n      color: var(--accent);\r\n      letter-spacing: 0.08em;\r\n      text-transform: uppercase;\r\n    }\r\n    .modal-close {\r\n      background: none;\r\n      border: none;\r\n      color: var(--text-muted);\r\n      cursor: pointer;\r\n      font-size: 18px;\r\n      line-height: 1;\r\n      padding: 4px;\r\n    }\r\n    .modal-close:hover { color: var(--text); }\r\n    .detail-row {\r\n      margin-bottom: 1.25rem;\r\n    }\r\n    .detail-label {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      color: var(--text-muted);\r\n      letter-spacing: 0.1em;\r\n      text-transform: uppercase;\r\n      margin-bottom: 4px;\r\n    }\r\n    .detail-value {\r\n      font-size: 14px;\r\n      color: var(--text);\r\n      line-height: 1.6;\r\n      word-break: break-all;\r\n    }\r\n    .detail-value.mono {\r\n      font-family: var(--mono);\r\n      font-size: 13px;\r\n      color: var(--accent);\r\n    }\r\n    .detail-message {\r\n      background: var(--bg);\r\n      border: 1px solid var(--border);\r\n      border-radius: 2px;\r\n      padding: 12px;\r\n      font-size: 13px;\r\n      color: var(--text);\r\n      line-height: 1.7;\r\n      white-space: pre-wrap;\r\n      word-break: break-all;\r\n    }\r\n\r\n    /* Loading spinner */\r\n    .spinner {\r\n      display: inline-block;\r\n      width: 14px; height: 14px;\r\n      border: 2px solid var(--border-light);\r\n      border-top-color: var(--accent);\r\n      border-radius: 50%;\r\n      animation: spin 0.6s linear infinite;\r\n      margin-right: 8px;\r\n      vertical-align: middle;\r\n    }\r\n    @keyframes spin { to { transform: rotate(360deg); } }\r\n\r\n    @media (max-width: 768px) {\r\n      .stats { grid-template-columns: 1fr; }\r\n      .container { padding: 1rem; }\r\n      th:nth-child(1), td:nth-child(1),\r\n      th:nth-child(4), td:nth-child(4) { display: none; }\r\n    }\r\n  \u003c/style\u003e\r\n\u003c/head\u003e\r\n\u003cbody\u003e\r\n\r\n\u003cheader\u003e\r\n  \u003cdiv class=\"logo\"\u003eADMIN / お問い合わせ管理\u003c/div\u003e\r\n  \u003cdiv class=\"header-right\"\u003e\r\n    \u003cdiv class=\"status-dot\"\u003e\u003c/div\u003e\r\n    \u003cspan class=\"status-text\" id=\"header-status\"\u003e--\u003c/span\u003e\r\n    \u003cbutton class=\"btn-refresh\" id=\"logout-btn\" style=\"display:none;\" onclick=\"logout()\"\u003eLOGOUT\u003c/button\u003e\r\n  \u003c/div\u003e\r\n\u003c/header\u003e\r\n\r\n\u003c!-- Login --\u003e\r\n\u003cdiv id=\"login-screen\"\u003e\r\n  \u003cdiv class=\"login-card\"\u003e\r\n    \u003ch2\u003eADMIN ACCESS\u003c/h2\u003e\r\n    \u003cp\u003e管理者パスワードを入力してください\u003c/p\u003e\r\n    \u003cdiv class=\"field\"\u003e\r\n      \u003clabel\u003ePassword\u003c/label\u003e\r\n      \u003cinput type=\"password\" id=\"password\" placeholder=\"••••••••\" onkeydown=\"if(event.key==='Enter')login()\"\u003e\r\n    \u003c/div\u003e\r\n    \u003cbutton class=\"btn-login\" onclick=\"login()\"\u003eログイン\u003c/button\u003e\r\n    \u003cdiv id=\"login-error\" class=\"login-error\"\u003e※ パスワードが正しくありません\u003c/div\u003e\r\n  \u003c/div\u003e\r\n\u003c/div\u003e\r\n\r\n\u003c!-- Dashboard --\u003e\r\n\u003cdiv id=\"dashboard\"\u003e\r\n  \u003cdiv class=\"container\"\u003e\r\n    \u003cdiv class=\"stats\"\u003e\r\n      \u003cdiv class=\"stat\"\u003e\r\n        \u003cdiv class=\"stat-label\"\u003eTotal\u003c/div\u003e\r\n        \u003cdiv class=\"stat-value\" id=\"stat-total\"\u003e—\u003c/div\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"stat\"\u003e\r\n        \u003cdiv class=\"stat-label\"\u003eToday\u003c/div\u003e\r\n        \u003cdiv class=\"stat-value\" id=\"stat-today\"\u003e—\u003c/div\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"stat\"\u003e\r\n        \u003cdiv class=\"stat-label\"\u003eLast Updated\u003c/div\u003e\r\n        \u003cdiv class=\"stat-value\" style=\"font-size:16px; padding-top:6px;\" id=\"stat-updated\"\u003e—\u003c/div\u003e\r\n      \u003c/div\u003e\r\n    \u003c/div\u003e\r\n\r\n    \u003cdiv class=\"toolbar\"\u003e\r\n      \u003cdiv class=\"toolbar-left\"\u003e\r\n        \u003cspan class=\"section-title\"\u003eINQUIRIES\u003c/span\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv style=\"display:flex; gap:0.75rem; align-items:center;\"\u003e\r\n        \u003cinput type=\"text\" class=\"search-input\" id=\"search\" placeholder=\"名前・メールで検索...\" oninput=\"filterTable()\"\u003e\r\n        \u003cbutton class=\"btn-refresh\" onclick=\"loadData()\"\u003e↻ REFRESH\u003c/button\u003e\r\n      \u003c/div\u003e\r\n    \u003c/div\u003e\r\n\r\n    \u003cdiv class=\"table-wrap\"\u003e\r\n      \u003ctable\u003e\r\n        \u003cthead\u003e\r\n          \u003ctr\u003e\r\n            \u003cth\u003eID\u003c/th\u003e\r\n            \u003cth\u003e名前\u003c/th\u003e\r\n            \u003cth\u003eメールアドレス\u003c/th\u003e\r\n            \u003cth\u003e件名\u003c/th\u003e\r\n            \u003cth\u003e内容\u003c/th\u003e\r\n            \u003cth\u003e送信日時\u003c/th\u003e\r\n          \u003c/tr\u003e\r\n        \u003c/thead\u003e\r\n        \u003ctbody id=\"table-body\"\u003e\r\n          \u003ctr class=\"empty-row\"\u003e\u003ctd colspan=\"6\"\u003e\u003cspan class=\"spinner\"\u003e\u003c/span\u003e読み込み中...\u003c/td\u003e\u003c/tr\u003e\r\n        \u003c/tbody\u003e\r\n      \u003c/table\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n\u003c/div\u003e\r\n\r\n\u003c!-- Modal --\u003e\r\n\u003cdiv class=\"modal-overlay\" id=\"modal\" onclick=\"closeModal(event)\"\u003e\r\n  \u003cdiv class=\"modal\"\u003e\r\n    \u003cdiv class=\"modal-header\"\u003e\r\n      \u003cspan class=\"modal-title\"\u003eDETAIL\u003c/span\u003e\r\n      \u003cbutton class=\"modal-close\" onclick=\"closeModalDirect()\"\u003e×\u003c/button\u003e\r\n    \u003c/div\u003e\r\n    \u003cdiv id=\"modal-content\"\u003e\u003c/div\u003e\r\n  \u003c/div\u003e\r\n\u003c/div\u003e\r\n\r\n\u003cscript\u003e\r\n  const API = \"https://9tv2kbxpih.execute-api.us-east-1.amazonaws.com/prod/contact\";\r\n  const ADMIN_PASSWORD = 'admin1234'; // ← パスワードを変更してください\r\n  let allData = [];\r\n\r\n  function login() {\r\n    const pw = document.getElementById('password').value;\r\n    if (pw === ADMIN_PASSWORD) {\r\n      document.getElementById('login-screen').style.display = 'none';\r\n      document.getElementById('dashboard').style.display = 'block';\r\n      document.getElementById('logout-btn').style.display = 'block';\r\n      loadData();\r\n    } else {\r\n      document.getElementById('login-error').style.display = 'block';\r\n    }\r\n  }\r\n\r\n  function logout() {\r\n    document.getElementById('login-screen').style.display = 'flex';\r\n    document.getElementById('dashboard').style.display = 'none';\r\n    document.getElementById('logout-btn').style.display = 'none';\r\n    document.getElementById('password').value = '';\r\n    document.getElementById('login-error').style.display = 'none';\r\n  }\r\n\r\n  async function loadData() {\r\n    const tbody = document.getElementById('table-body');\r\n    tbody.innerHTML = '\u003ctr class=\"empty-row\"\u003e\u003ctd colspan=\"6\"\u003e\u003cspan class=\"spinner\"\u003e\u003c/span\u003e読み込み中...\u003c/td\u003e\u003c/tr\u003e';\r\n    document.getElementById('header-status').textContent = 'loading...';\r\n\r\n    try {\r\n      const res = await fetch(API);\r\n      if (!res.ok) throw new Error('API error: ' + res.status);\r\n      allData = await res.json();\r\n      renderTable(allData);\r\n\r\n      const today = new Date().toDateString();\r\n      const todayCount = allData.filter(d =\u003e new Date(d.timestamp).toDateString() === today).length;\r\n      document.getElementById('stat-total').textContent = allData.length;\r\n      document.getElementById('stat-today').textContent = todayCount;\r\n      document.getElementById('stat-updated').textContent = new Date().toLocaleTimeString('ja-JP');\r\n      document.getElementById('header-status').textContent = allData.length + ' records';\r\n    } catch (e) {\r\n      tbody.innerHTML = '\u003ctr class=\"empty-row\"\u003e\u003ctd colspan=\"6\"\u003eデータの取得に失敗しました: ' + e.message + '\u003c/td\u003e\u003c/tr\u003e';\r\n      document.getElementById('header-status').textContent = 'error';\r\n    }\r\n  }\r\n\r\n  function renderTable(data) {\r\n    const tbody = document.getElementById('table-body');\r\n    if (data.length === 0) {\r\n      tbody.innerHTML = '\u003ctr class=\"empty-row\"\u003e\u003ctd colspan=\"6\"\u003eデータがありません\u003c/td\u003e\u003c/tr\u003e';\r\n      return;\r\n    }\r\n    tbody.innerHTML = data.map(item =\u003e `\r\n\u003ctr onclick=\"showDetail('${item.id}')\"\u003e\r\n  \u003ctd class=\"td-id\"\u003e${item.id ? item.id.substring(0, 8) + '...' : '—'}\u003c/td\u003e\r\n  \u003ctd class=\"td-name\"\u003e${escape(item.name || '—')}\u003c/td\u003e\r\n  \u003ctd class=\"td-email\"\u003e${escape(item.email || '—')}\u003c/td\u003e\r\n  \u003ctd class=\"td-subject\"\u003e${escape(item.subject || '—')}\u003c/td\u003e\r\n  \u003ctd class=\"td-message\"\u003e${escape(item.message || '—')}\u003c/td\u003e\r\n  \u003ctd class=\"td-time\"\u003e${formatDate(item.timestamp)}\u003c/td\u003e\r\n\u003c/tr\u003e\r\n    `).join('');\r\n  }\r\n\r\n  function filterTable() {\r\n    const q = document.getElementById('search').value.toLowerCase();\r\n    if (!q) { renderTable(allData); return; }\r\n    const filtered = allData.filter(d =\u003e\r\n      (d.name || '').toLowerCase().includes(q) ||\r\n      (d.email || '').toLowerCase().includes(q) ||\r\n      (d.subject || '').toLowerCase().includes(q)\r\n    );\r\n    renderTable(filtered);\r\n  }\r\n\r\n  function showDetail(id) {\r\n    const item = allData.find(d =\u003e d.id === id);\r\n    if (!item) return;\r\n    document.getElementById('modal-content').innerHTML = `\r\n      \u003cdiv class=\"detail-row\"\u003e\r\n        \u003cdiv class=\"detail-label\"\u003eID\u003c/div\u003e\r\n        \u003cdiv class=\"detail-value mono\"\u003e${escape(item.id || '—')}\u003c/div\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"detail-row\"\u003e\r\n        \u003cdiv class=\"detail-label\"\u003e送信日時\u003c/div\u003e\r\n        \u003cdiv class=\"detail-value\"\u003e${formatDateFull(item.timestamp)}\u003c/div\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"detail-row\"\u003e\r\n        \u003cdiv class=\"detail-label\"\u003eお名前\u003c/div\u003e\r\n        \u003cdiv class=\"detail-value\"\u003e${escape(item.name || '—')}\u003c/div\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"detail-row\"\u003e\r\n        \u003cdiv class=\"detail-label\"\u003eメールアドレス\u003c/div\u003e\r\n        \u003cdiv class=\"detail-value mono\"\u003e${escape(item.email || '—')}\u003c/div\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"detail-row\"\u003e\r\n        \u003cdiv class=\"detail-label\"\u003e件名\u003c/div\u003e\r\n        \u003cdiv class=\"detail-value\"\u003e${escape(item.subject || '件名なし')}\u003c/div\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"detail-row\"\u003e\r\n        \u003cdiv class=\"detail-label\"\u003eお問い合わせ内容\u003c/div\u003e\r\n        \u003cdiv class=\"detail-message\"\u003e${escape(item.message || '—')}\u003c/div\u003e\r\n      \u003c/div\u003e\r\n    `;\r\n    document.getElementById('modal').classList.add('open');\r\n  }\r\n\r\n  function closeModal(e) {\r\n    if (e.target === document.getElementById('modal')) closeModalDirect();\r\n  }\r\n  function closeModalDirect() {\r\n    document.getElementById('modal').classList.remove('open');\r\n  }\r\n\r\n  function escape(str) {\r\n    return String(str)\r\n      .replace(/\u0026/g, '\u0026amp;')\r\n      .replace(/\u003c/g, '\u0026lt;')\r\n      .replace(/\u003e/g, '\u0026gt;')\r\n      .replace(/\"/g, '\u0026quot;');\r\n  }\r\n\r\n  function formatDate(ts) {\r\n    if (!ts) return '—';\r\n    const d = new Date(ts);\r\n    return d.toLocaleDateString('ja-JP') + ' ' + d.toLocaleTimeString('ja-JP', {hour:'2-digit', minute:'2-digit'});\r\n  }\r\n\r\n  function formatDateFull(ts) {\r\n    if (!ts) return '—';\r\n    return new Date(ts).toLocaleString('ja-JP');\r\n  }\r\n\u003c/script\u003e\r\n\u003c/body\u003e\r\n\u003c/html\u003e\r\n",
